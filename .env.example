# ---- REQUIRED: Get these before running ----

# data.gov.in APMC Mandi Prices API
# Get production key at: https://data.gov.in/user/register
# WARNING: DEMO_KEY is limited to 30 req/hr - will kill your demo
DATA_GOV_API_KEY=your_production_key_here

# Google Gemini API (for Vision + LangGraph LLM)
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Supabase (create free project at supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here

# Telegram Bot Token
# Create via @BotFather on Telegram: /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here
